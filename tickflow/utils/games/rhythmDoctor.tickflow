0x102 0
0x100 0, 0x30
rest 0x18
0x101 4
rest 0x18
rest 0
0x100 0, 0x30
rest 0x18
0x101 3
rest 0x18

play_sfx 0x10011AA
0x100 0, 0x30
rest 0x18
0x101 0
rest 0x18
0x8F 3 // combo rating text epilogue
